    "contract": {
        "name": "AccountRegistry",
        "methods": [
            {
                "name": "create",
                "args": [],
                "readonly": false,
                "returns": {
                    "type": "void"
                }
            },
            {
                "name": "bootstrap",
                "args": [
                    {
                        "type": "byte[]",
                        "name": "governance_address"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                }
            },
            {
                "name": "register_institution",
                "args": [
                    {
                        "type": "byte[]",
                        "name": "kyb_hash",
                        "desc": "- SHA-256 hash of the KYB document bundle"
                    },
                    {
                        "type": "uint64",
                        "name": "tier",
                        "desc": "- 1=DAO, 2=Fintech, 3=SMB"
                    },
                    {
                        "type": "byte[]",
                        "name": "jurisdiction",
                        "desc": "- ISO 3166-1 alpha-2 (e.g. Bytes('US'))"
                    },
                    {
                        "type": "uint64",
                        "name": "multisig_threshold",
                        "desc": "- required signers for vault multisig (1-10)"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "An institution calls this to register itself and trigger the KYB flow.\nThe kyb_hash is the SHA-256 of the documents bundle stored off-chain\n(e.g. in IPFS or the API database). The KYB service calls attest_kyb\nonce verification passes."
            },
            {
                "name": "attest_kyb",
                "args": [
                    {
                        "type": "address",
                        "name": "institution",
                        "desc": "- the institution's wallet address"
                    },
                    {
                        "type": "uint64",
                        "name": "approved_products",
                        "desc": "- bitmask of approved product flags"
                    },
                    {
                        "type": "uint64",
                        "name": "tier",
                        "desc": "- confirmed tier (may differ from self-declared)"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Called by the Didit webhook processor (via the API, via Governance admin)\nonce KYB verification passes. Sets status to APPROVED and grants products."
            },
            {
                "name": "reject_kyb",
                "args": [
                    {
                        "type": "address",
                        "name": "institution"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Reject a KYB application."
            },
            {
                "name": "suspend_institution",
                "args": [
                    {
                        "type": "address",
                        "name": "institution"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Suspend an approved institution (e.g. sanctions hit, fraud detection)."
            },
            {
                "name": "reinstate_institution",
                "args": [
                    {
                        "type": "address",
                        "name": "institution"
                    },
                    {
                        "type": "uint64",
                        "name": "approved_products"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Reinstate a suspended institution."
            },
            {
                "name": "get_profile",
                "args": [
                    {
                        "type": "address",
                        "name": "institution"
                    }
                ],
                "readonly": true,
                "returns": {
                    "type": "(byte[],uint64,byte[],uint64,uint64,uint64,uint64,uint64)"
                }
            },
            {
                "name": "is_approved",
                "args": [
                    {
                        "type": "address",
                        "name": "institution"
                    }
                ],
                "readonly": true,
                "returns": {
                    "type": "bool"
                }
            },
            {
                "name": "has_product",
                "args": [
                    {
                        "type": "address",
                        "name": "institution"
                    },
                    {
                        "type": "uint64",
                        "name": "product_bit"
                    }
                ],
                "readonly": true,
                "returns": {
                    "type": "bool"
                }
            },
            {
                "name": "update_governance",
                "args": [
                    {
                        "type": "byte[]",
                        "name": "new_governance"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                }
            }
        ],
        "networks": {}
